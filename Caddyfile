vpsconnect.heiphaistos.org {
    encode gzip zstd

    # WebSocket log streams
    handle /ws/* {
        reverse_proxy backend:4000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Backend API
    handle /api/* {
        reverse_proxy backend:4000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Frontend (Next.js)
    handle {
        reverse_proxy frontend:3000 {
            header_up Host {host}
        }
    }

    log {
        output file /var/log/caddy/vpsconnect.log {
            roll_size 10MB
            roll_keep 3
        }
    }
}
